rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(data) {
      return isSignedIn() && data.ownerId == request.auth.uid;
    }

    // Projekty — každý dokument musí mať ownerId == prihlásený užívateľ.
    // Nikto iný (vrátane iných prihlásených účtov) nevidí cudzie projekty.
    match /projects/{projectId} {
      allow create: if isSignedIn()
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.name is string;

      allow read, delete: if isOwner(resource.data);

      allow update: if isOwner(resource.data)
        && request.resource.data.ownerId == request.auth.uid;
    }

    // Kontrolný záznam pre vault passphrase — ID dokumentu == UID užívateľa,
    // takže pravidlo nemusí čítať dáta dokumentu, len porovná ID s auth.uid.
    match /vaultMeta/{uid} {
      allow read, write: if isSignedIn() && request.auth.uid == uid;
    }

    // Všetko ostatné je explicitne zakázané.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
